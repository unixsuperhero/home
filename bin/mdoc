#!/usr/bin/env bash
# mdoc — Convert a markdown file to styled HTML using pandoc,
#         update ~/claude/index.html, and open in browser.
#
# Usage:
#   mdoc <file.md>
#   mdoc <file.md> --title "Custom Title" --desc "Brief description"
#   mdoc <file.md> --toc
#   mdoc <file.md> --recursive
#   echo "# Hello" | mdoc - --title "Piped Input"
#
# Options:
#   -t, --title <str>   Override document title (default: first H1 or filename)
#   -d, --desc  <str>   Short description shown in the index
#       --toc           Inject a table of contents sidebar
#       --no-open       Skip opening in browser
#   -r, --recursive     Follow and convert all linked .md files transitively

set -euo pipefail

CLAUDE_DIR="$HOME/claude"
DOCS_DIR="$CLAUDE_DIR/docs"
INDEX_JSON="$CLAUDE_DIR/index.json"
INDEX_HTML="$CLAUDE_DIR/index.html"
TEMPLATE="$HOME/.pandoc/templates/claude-docs.html"

mkdir -p "$DOCS_DIR"

# ── Argument parsing ──────────────────────────────────────────────────────────
INPUT=""
TITLE=""
DESC=""
TOC=false
DO_OPEN=true
RECURSIVE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -t|--title)     TITLE="$2";     shift 2 ;;
    -d|--desc)      DESC="$2";      shift 2 ;;
    --toc)          TOC=true;       shift   ;;
    --no-open)      DO_OPEN=false;  shift   ;;
    -r|--recursive) RECURSIVE=true; shift   ;;
    -*)             echo "Unknown flag: $1" >&2; exit 1 ;;
    *)              INPUT="$1";     shift   ;;
  esac
done

if [[ -z "$INPUT" ]]; then
  echo "Usage: mdoc <file.md> [--title 'Title'] [--desc 'Description'] [--toc] [--recursive]" >&2
  exit 1
fi

DATE=$(date +%Y-%m-%d)

# Collect temp files for cleanup on exit
CLEANUP_FILES=()
trap '[[ ${#CLEANUP_FILES[@]} -gt 0 ]] && rm -f "${CLEANUP_FILES[@]}" 2>/dev/null; true' EXIT

# ── Handle stdin ──────────────────────────────────────────────────────────────
if [[ "$INPUT" == "-" ]]; then
  if [[ "$RECURSIVE" == true ]]; then
    echo "mdoc: --recursive is not supported with stdin input" >&2
    exit 1
  fi
  TMPMD=$(mktemp /tmp/mdoc-XXXXXX.md)
  CLEANUP_FILES+=("$TMPMD")
  cat > "$TMPMD"
  INPUT="$TMPMD"
fi

# ── Helper: extract first H1 title from a markdown file ──────────────────────
_mdoc_get_title() {
  local t
  t=$(awk '/^# /{sub(/^# /, ""); print; exit}' "$1")
  [[ -z "$t" ]] && t=$(basename "${1%.md}")
  printf '%s' "$t"
}

# ── Helper: title → URL slug ──────────────────────────────────────────────────
_mdoc_slug() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-//;s/-$//'
}

# ── Helper: preprocess markdown (ensures blank lines before tables/headings) ──
_mdoc_preprocess() {
  local src="$1" dst="$2"
  ruby -e '
    lines = ARGF.readlines
    out   = []
    lines.each_with_index do |line, i|
      prev = out.last
      needs_blank = prev && !prev.strip.empty? &&
        (
          (line.start_with?("|") && !prev.start_with?("|")) ||
          line.match?(/^#+\s/)
        )
      out << "\n" if needs_blank
      out << line
    end
    print out.join
  ' "$src" > "$dst"
}

# ── Helper: run pandoc on a preprocessed file ─────────────────────────────────
# Args: src outfile title [lua_filter] [input_dir]
_mdoc_pandoc() {
  local src="$1" outfile="$2" title="$3" lua_filter="${4:-}" input_dir="${5:-}"

  local args=(
    "$src"
    --template="$TEMPLATE"
    --syntax-highlighting=breezedark
    --metadata "title=$title"
    --metadata "date=$(date '+%B %-d, %Y')"
    --standalone
    --wrap=none
    -o "$outfile"
  )
  [[ "$TOC"           == true ]] && args+=(--toc --toc-depth=3)
  [[ -n "$lua_filter"         ]] && args+=(--lua-filter="$lua_filter")
  [[ -n "$input_dir"          ]] && args+=(--metadata "input_dir=$input_dir")

  pandoc "${args[@]}"
}

# ── Helper: update index.json and regenerate index.html ──────────────────────
# Reads all values from environment variables (MDOC_*) so it's callable
# per-file in loops without heredoc interpolation issues.
_mdoc_update_index() {
  MDOC_OUTFILE="$1" \
  MDOC_TITLE="$2" \
  MDOC_DESC="${3:-}" \
  MDOC_DATE="$DATE" \
  MDOC_CLAUDE_DIR="$CLAUDE_DIR" \
  MDOC_INDEX_JSON="$INDEX_JSON" \
  MDOC_INDEX_HTML="$INDEX_HTML" \
  python3 - <<'PYEOF'
import json, os
from datetime import datetime

outfile    = os.environ['MDOC_OUTFILE']
title      = os.environ['MDOC_TITLE']
desc       = os.environ['MDOC_DESC']
date_str   = os.environ['MDOC_DATE']
claude_dir = os.environ['MDOC_CLAUDE_DIR']
index_json = os.environ['MDOC_INDEX_JSON']
index_html = os.environ['MDOC_INDEX_HTML']

rel = os.path.relpath(outfile, claude_dir)

entry = {
    "title": title,
    "file":  rel,
    "date":  date_str,
    "desc":  desc,
    "ts":    datetime.now().isoformat()
}

entries = []
if os.path.exists(index_json):
    try:
        with open(index_json) as f:
            entries = json.load(f)
    except Exception:
        entries = []

entries = [e for e in entries if e.get("file") != rel]
entries.insert(0, entry)

with open(index_json, "w") as f:
    json.dump(entries, f, indent=2)

# ── Regenerate index.html ──────────────────────────────────────────────────────
rows = ""
for e in entries:
    t  = e.get("title", "Untitled")
    f  = e.get("file",  "")
    d  = e.get("date",  "")
    de = e.get("desc",  "")
    rows += f"""
      <tr>
        <td class="date">{d}</td>
        <td class="title"><a href="{f}">{t}</a>{f'<span class="desc">{de}</span>' if de else ''}</td>
      </tr>"""

now   = datetime.now().strftime("%B %-d, %Y at %H:%M")
count = len(entries)

html = f"""<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Claude Docs Index</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..700&family=Lora:ital,wght@0,400;1,400&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
  <style>
    :root {{
      --bg:      #0c0a08;
      --surface: #141210;
      --border:  #2d2820;
      --text:    #e6ddd0;
      --text2:   #9a9080;
      --text3:   #5a5248;
      --accent:  #c9832a;
      --accent2: #e8a03e;
      --radius:  4px;
    }}
    *, *::before, *::after {{ box-sizing: border-box; margin: 0; padding: 0; }}
    html {{ font-size: 16px; -webkit-font-smoothing: antialiased; }}
    body {{
      background: var(--bg);
      color: var(--text);
      font-family: 'Lora', Georgia, serif;
      min-height: 100vh;
      padding: 3rem 2rem 6rem;
    }}
    .wrap {{ max-width: 760px; margin: 0 auto; }}
    header {{ margin-bottom: 3rem; border-bottom: 1px solid var(--border); padding-bottom: 1.5rem; }}
    header h1 {{
      font-family: 'Fraunces', serif;
      font-size: clamp(1.6rem, 4vw, 2.4rem);
      font-weight: 700;
      letter-spacing: -0.01em;
      margin-bottom: 0.4rem;
    }}
    header h1 span {{ color: var(--accent); }}
    .meta {{
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      color: var(--text3);
      letter-spacing: 0.06em;
    }}
    table {{
      width: 100%;
      border-collapse: collapse;
    }}
    th {{
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text3);
      text-align: left;
      padding: 0 0.75rem 0.6rem;
      border-bottom: 1px solid var(--accent);
    }}
    td {{
      padding: 0.7rem 0.75rem;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }}
    tr:hover td {{ background: #161310; }}
    td.date {{
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      color: var(--text3);
      white-space: nowrap;
      width: 7rem;
      padding-top: 0.8rem;
    }}
    td.title a {{
      color: var(--text);
      text-decoration: none;
      font-size: 1rem;
      display: block;
      margin-bottom: 0.15rem;
    }}
    td.title a:hover {{ color: var(--accent2); }}
    .desc {{
      display: block;
      font-size: 0.8rem;
      color: var(--text2);
      margin-top: 0.1rem;
      font-style: italic;
    }}
    .empty {{
      text-align: center;
      padding: 4rem 0;
      color: var(--text3);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
    }}
    ::-webkit-scrollbar {{ width: 6px; }}
    ::-webkit-scrollbar-thumb {{ background: var(--border); border-radius: 3px; }}
    body.light {{
      --bg: #faf8f5; --surface: #f3f0eb; --border: #ddd8d0;
      --text: #1a1510; --text2: #6a6258; --text3: #9a9088;
      --accent: #b06e1a; --accent2: #c8821e;
    }}
    #toggle {{
      position: fixed; top: 1rem; right: 1rem;
      background: var(--surface); border: 1px solid var(--border);
      color: var(--text2); width: 2rem; height: 2rem;
      border-radius: 50%; cursor: pointer; font-size: 0.85rem;
      display: flex; align-items: center; justify-content: center;
    }}
  </style>
</head>
<body>
<button id="toggle" title="Toggle theme">&#9681;</button>
<div class="wrap">
  <header>
    <h1>Claude <span>Docs</span></h1>
    <div class="meta">
      {count} document{'s' if count != 1 else ''} &nbsp;·&nbsp; last updated {now}
    </div>
  </header>
  {'<table><thead><tr><th>Date</th><th>Document</th></tr></thead><tbody>' + rows + '</tbody></table>' if entries else '<div class="empty">No documents yet.</div>'}
</div>
<script>
  const t = document.getElementById('toggle');
  if (localStorage.getItem('mdoc-theme') === 'light') document.body.classList.add('light');
  t.addEventListener('click', () => {{
    document.body.classList.toggle('light');
    localStorage.setItem('mdoc-theme', document.body.classList.contains('light') ? 'light' : 'dark');
  }});
</script>
</body>
</html>"""

with open(index_html, "w") as f:
    f.write(html)

print(f"mdoc: index updated ({count} docs) → {index_html}")
PYEOF
}

# ── Helper: convert a single file (preprocess + pandoc + index update) ────────
# Args: input_abs title desc [lua_filter]
# Prints the output HTML path.
_mdoc_convert_file() {
  local input_abs="$1" title="$2" desc="$3" lua_filter="${4:-}"
  local input_dir slug outfile processed

  input_dir=$(dirname "$input_abs")
  slug=$(_mdoc_slug "$title")
  outfile="$DOCS_DIR/${DATE}-${slug}.html"

  processed=$(mktemp /tmp/mdoc-processed-XXXXXX.md)
  CLEANUP_FILES+=("$processed")

  _mdoc_preprocess "$input_abs" "$processed"
  _mdoc_pandoc "$processed" "$outfile" "$title" "$lua_filter" "$input_dir"
  echo "mdoc: generated $outfile" >&2

  _mdoc_update_index "$outfile" "$title" "$desc"

  printf '%s' "$outfile"
}

# ══════════════════════════════════════════════════════════════════════════════
# ── Recursive helpers ─────────────────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════════════

# BFS over markdown link graph; prints one absolute path per line.
_mdoc_collect_files() {
  python3 - "$1" <<'PYEOF'
import sys, os, re

def collect(root):
    root = os.path.abspath(root)
    seen, queue, ordered = set(), [root], []
    while queue:
        path = os.path.normpath(queue.pop(0))
        if path in seen or not os.path.isfile(path):
            continue
        seen.add(path)
        ordered.append(path)
        base = os.path.dirname(path)
        with open(path, errors='replace') as f:
            content = f.read()
        for m in re.finditer(r'\[[^\]]*\]\(([^)#\s]+\.md)(?:#[^)]*)?\)', content):
            link = m.group(1)
            if link.startswith(('http://', 'https://', 'mailto:')):
                continue
            queue.append(os.path.normpath(os.path.join(base, link)))
    return ordered

for f in collect(sys.argv[1]):
    print(f)
PYEOF
}

# Given a list of absolute .md paths, returns JSON mapping each path to its
# output HTML filename (just the basename, since all outputs land in DOCS_DIR).
_mdoc_build_link_map() {
  python3 - "$DATE" "$@" <<'PYEOF'
import sys, os, re, json

date  = sys.argv[1]
files = sys.argv[2:]

def get_title(path):
    with open(path, errors='replace') as f:
        for line in f:
            m = re.match(r'^# (.+)', line)
            if m:
                return m.group(1).strip()
    return os.path.splitext(os.path.basename(path))[0]

def make_slug(title):
    s = re.sub(r'[^a-z0-9]+', '-', title.lower())
    return s.strip('-')

result = {}
for path in files:
    slug = make_slug(get_title(path))
    result[path] = f"{date}-{slug}.html"

print(json.dumps(result))
PYEOF
}

# Writes a Lua filter to $1 that rewrites .md links to their HTML equivalents.
# The map (abs_src_path → output_filename) is baked in as a Lua table.
_mdoc_write_lua_filter() {
  local outfile="$1" link_map_json="$2"
  python3 - "$outfile" "$link_map_json" <<'PYEOF'
import sys, json

outfile      = sys.argv[1]
link_map     = json.loads(sys.argv[2])

map_lines = ['local map = {}']
for src, dst in link_map.items():
    s = src.replace('\\', '\\\\').replace('"', '\\"')
    d = dst.replace('\\', '\\\\').replace('"', '\\"')
    map_lines.append(f'map["{s}"] = "{d}"')

lua = r"""
local input_dir = ""

-- Pure-Lua path normalizer: handles ../ and ./ without shell calls
local function normalize(path)
  local parts, is_abs = {}, path:sub(1,1) == "/"
  for part in path:gmatch("[^/]+") do
    if part == ".." and #parts > 0 then
      table.remove(parts)
    elseif part ~= "." and part ~= "" then
      table.insert(parts, part)
    end
  end
  local result = table.concat(parts, "/")
  return is_abs and ("/" .. result) or result
end

function Meta(m)
  if m.input_dir then
    input_dir = pandoc.utils.stringify(m.input_dir)
    if input_dir:sub(-1) ~= "/" then input_dir = input_dir .. "/" end
    m.input_dir = nil  -- don't leak into output
  end
  return m
end

function Link(el)
  local target = el.target
  -- Skip external links and pure anchors
  if target:match("^https?://") or target:match("^mailto:") or target:match("^#") then
    return el
  end
  -- Separate path from anchor fragment
  local path, anchor = target:match("^(.-)(%#.*)$")
  if not path then path = target; anchor = "" end
  -- Only rewrite .md links
  if not path:match("%.md$") then return el end
  -- Resolve to absolute path
  local abs_path = path:sub(1,1) == "/" and normalize(path)
                                         or normalize(input_dir .. path)
  if map[abs_path] then
    el.target = map[abs_path] .. anchor
    return el
  end
  return el
end
"""

with open(outfile, 'w') as f:
    f.write('\n'.join(map_lines))
    f.write(lua)
PYEOF
}

# ══════════════════════════════════════════════════════════════════════════════
# ── Main flow ─────────────────────────────────════════════════════════════════
# ══════════════════════════════════════════════════════════════════════════════

OUTFILE=""

if [[ "$RECURSIVE" == true ]]; then
  INPUT_ABS=$(cd "$(dirname "$INPUT")" && pwd)/$(basename "$INPUT")

  echo "mdoc: collecting linked .md files from $INPUT_ABS ..."
  mapfile -t ALL_FILES < <(_mdoc_collect_files "$INPUT_ABS")
  echo "mdoc: found ${#ALL_FILES[@]} file(s)"

  # Build map: abs_path → output html filename
  LINK_MAP_JSON=$(_mdoc_build_link_map "${ALL_FILES[@]}")

  # Write Lua filter with map baked in
  LUA_FILTER=$(mktemp /tmp/mdoc-links-XXXXXX.lua)
  CLEANUP_FILES+=("$LUA_FILTER")
  _mdoc_write_lua_filter "$LUA_FILTER" "$LINK_MAP_JSON"

  for file in "${ALL_FILES[@]}"; do
    file_title=$(_mdoc_get_title "$file")
    file_desc=""
    # Apply user-supplied title/desc only to the root file
    if [[ "$file" == "$INPUT_ABS" ]]; then
      [[ -n "$TITLE" ]] && file_title="$TITLE"
      file_desc="$DESC"
    fi
    out=$(_mdoc_convert_file "$file" "$file_title" "$file_desc" "$LUA_FILTER")
    [[ "$file" == "$INPUT_ABS" ]] && OUTFILE="$out"
  done

else
  # ── Single-file mode (original behavior) ────────────────────────────────────
  INPUT_ABS=$(cd "$(dirname "$INPUT")" && pwd)/$(basename "$INPUT")
  [[ -z "$TITLE" ]] && TITLE=$(_mdoc_get_title "$INPUT_ABS")
  OUTFILE=$(_mdoc_convert_file "$INPUT_ABS" "$TITLE" "$DESC")
fi

# ── Open ──────────────────────────────────────────────────────────────────────
if [[ "$DO_OPEN" == true ]] && [[ -n "$OUTFILE" ]]; then
  open "$OUTFILE"
fi
